num1 = float(input("შეიყვანე პირველი რიცხვი: "))
num2 = float(input("შეიყვანე მეორე რიცხვი: "))

operation = input("აირჩიე მოქმედება (+, -, *, /): ")

if operation == "+":
    print("შედეგი:", num1 + num2)

elif operation == "-":
    print("შედეგი:", num1 - num2)

elif operation == "*":
    print("შედეგი:", num1 * num2)

elif operation == "/":
    if num2 == 0:
        print("შეცდომა: ნულზე გაყოფა არ შეიძლება!")
else:
    print("შედეგი:", num1 / num2)

else:
    print("არასწორი მოქმედება!")
